run = "streamlit run app.py --server.port 8501 --server.address 0.0.0.0"
modules = ["python-3.11"]

[nix]
channel = "stable-25_05"
packages = ["cacert", "glibcLocales"]

[agent]
expertMode = true
integrations = ["python_gemini_ai_integrations:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "streamlit run app.py --server.port 5000 --server.address 0.0.0.0"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[userenv]

[userenv.shared]
SMTP_HOST = "smtp.dreamhost.com"
SMTP_PORT = "587"
FROM_EMAIL = "turismo@iaesmartguide.com.br"
SMTP_USER = "turismo@iaesmartguide.com.br"
GEMINI_MODEL = "gemini-2.0-flash"

[deployment]
deploymentTarget = "vm"
run = ["streamlit", "run", "app.py", "--server.port=5000", "--server.address=0.0.0.0"]
